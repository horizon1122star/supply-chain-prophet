# backend/.env — copy to .env and fill in your keys

# REQUIRED for AI synthesis (Groq Llama 3.3 - ~$0.00 / free tier)
# Get free credits at: https://console.groq.com
GROQ_API_KEY=gsk_your_key_here

# NOTE: Live news is powered by Google News RSS (100% Free, No Key Required)
# OPTIONAL — Supabase for historical memory (free tier)
# Get at: https://supabase.com (completely free)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJyour-anon-key

# OPTIONAL — Alpha Vantage backup (25 calls/day free)
ALPHA_VANTAGE_KEY=your-key-here

# NOTE: These APIs need NO KEY and are completely FREE:
# - Open-Meteo (weather): https://open-meteo.com
# - Marine API (wave heights): https://marine-api.open-meteo.com
# - GDELT Project (geopolitical): https://www.gdeltproject.org
# - NOAA NHC (storms): https://www.nhc.noaa.gov
# - yfinance (stock data via Yahoo Finance)
